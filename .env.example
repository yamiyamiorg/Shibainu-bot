# Discord Bot Token (必須)
DISCORD_TOKEN=

# Discord Application Client ID (コマンド登録に必須)
CLIENT_ID=1463309552320512163

# Database (Yami機能で使用)
DATABASE_PATH=./data/yami.sqlite

# Google Gemini API (Yami機能を有効化する場合)
GEMINI_API_KEY=

# Choco feature settings (Choco機能を有効化する場合)
CHOCO_DIR=./images
CHOCO_STABLE_SEC=5
CHOCO_MAX_MB=20
CHOCO_REPLY_EPHEMERAL=false

# Boost
# テストサーバーID
BOOST_TEST_GUILD_IDS=1455097564759330958

# （任意）テスト送信先チャンネル
BOOST_TEST_CHANNEL_ID=1473078389442351277

# Logging
LOG_LEVEL=info  # debug, info, warn, error

# Environment
NODE_ENV=production

# DiaryReaction機能 - 秘密の日記フォーラムへのAI絵文字リアクション
# テスト環境のフォーラムチャンネルID
DIARY_FORUM_CHANNEL_ID_TEST=
# 本番環境のフォーラムチャンネルID
DIARY_FORUM_CHANNEL_ID_PROD=
# 遅延設定（任意・単位はミリ秒）
# DIARY_REACTION_DELAY_MIN_MS=30000
# DIARY_REACTION_DELAY_MAX_MS=120000
# 絵文字の数（任意・デフォルト3）
# DIARY_REACTION_COUNT=3

# ServerStats拡張設定
# キーワードトレンド収集対象チャンネルID（カンマ区切り・設定しない場合はトレンド非表示）
SERVERSTATS_KEYWORD_CHANNELS=
# マイルストーン目標値（カンマ区切り）
SERVERSTATS_MILESTONES=1500,2000,3000,5000

# Analytics機能（活動分析・AIレポート自動投稿）
# レポートを追記投稿するテキストチャンネルのID
# 本番サーバー
ANALYTICS_PROD_GUILD_ID=1450709451488100396
ANALYTICS_PROD_CHANNEL_ID=
# テストサーバー
ANALYTICS_TEST_GUILD_ID=1455097564759330958
ANALYTICS_TEST_CHANNEL_ID=
# 日次レポート送信時刻（JST・デフォルト: 6時0分）
# ANALYTICS_DAILY_HOUR=7
# ANALYTICS_DAILY_MINUTE=0
